# macOS
.DS_Store

# Local DB dump (contains real production data, not for git)
/db-init/

# Track only the theme inside wp-content — ignore everything else in public_html
/public_html/*
!/public_html/wp-content
/public_html/wp-content/*
!/public_html/wp-content/themes
/public_html/wp-content/themes/*
!/public_html/wp-content/themes/nklv-dsgn
